# ====================================================================
#  Georgia State Roleplay - Verification Bot  |  Environment config
#  Copy this file to ".env" and fill in the values.
# ====================================================================

# ---- Discord bot ----------------------------------------------------
# Bot token from https://discord.com/developers/applications -> Bot
DISCORD_TOKEN=
# Application (client) ID from the General Information page
DISCORD_CLIENT_ID=
# The single guild (server) this bot serves. Slash commands register here instantly.
GUILD_ID=

# Role given to verified members
VERIFIED_ROLE_ID=1487127237777031183
# Channel that receives a copy of every "verified" message (audit log)
LOG_CHANNEL_ID=1505555570290069635
# (Optional) Role allowed to use /fverify. If blank, anyone with the
# "Manage Server" permission can force-verify.
MOD_ROLE_ID=

# Should the verified confirmation be DMed to the user? (true/false)
# If false it is posted in LOG_CHANNEL_ID only.
VERIFIED_DM=true

# ---- Roblox OAuth 2.0 ----------------------------------------------
# Create an app at https://create.roblox.com/dashboard/credentials
# Redirect URI must be exactly:  <BASE_URL>/auth/roblox/callback
# Scopes required: openid profile
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=

# ---- Website / server ----------------------------------------------
# Public base URL of this site (no trailing slash). Used in links + OAuth redirect.
# e.g. https://verify.georgiastateroleplay.com  (or http://YOUR_LXC_IP:3000 for testing)
BASE_URL=http://localhost:3000
# Port the web server listens on (behind your reverse proxy)
PORT=3000

# Secret used to sign the 10-minute verification links + OAuth state.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_SECRET=change-me-to-a-long-random-string
# How long a verification link stays valid, in seconds (default 600 = 10 min)
TOKEN_TTL_SECONDS=600

# ---- Branding (used in embeds + website) ---------------------------
SERVER_NAME=Georgia State Roleplay
# Public invite shown on the success screen / help
DISCORD_INVITE_URL=https://discord.gg/
# Custom emojis used in the embeds (full <:name:id> form)
EMOJI_BRAND=<:unknown:1519043945290535102>
EMOJI_HELP=<:unknown:1492185664211386561>

# Where the SQLite database file lives
DATABASE_PATH=./data/verify.db
